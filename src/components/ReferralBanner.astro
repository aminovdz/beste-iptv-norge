---
import { Gift, Share2 } from 'lucide-astro';

const siteUrl = "https://iptv-norge.net";
const whatsappShareUrl = `https://wa.me/?text=${encodeURIComponent("Sjekk ut denne fantastiske IPTV-tjenesten: " + siteUrl)}`;
---

<section id="section-referral-gamma" class="py-12 bg-linear-to-r from-primary/10 to-secondary/10 border-y border-glass-border">
	<div class="max-container flex flex-col md:flex-row items-center justify-between gap-8">
		<div class="flex items-center gap-6">
			<div class="w-16 h-16 bg-primary rounded-2xl flex items-center justify-center animate-bounce">
				<Gift class="w-8 h-8 text-white" />
			</div>
			<div>
				<h2 class="text-2xl font-bold">Tips en venn og få 1 måned GRATIS!</h2>
				<p class="text-gray-400">Del iptv-norge.net med vennene dine. Når de abonnerer, får DERE BEGGE 1 måned ekstra.</p>
			</div>
		</div>
		
		<div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto">
			<a href={whatsappShareUrl} target="_blank" rel="noopener noreferrer" class="btn-primary flex items-center justify-center gap-2">
				<Share2 class="w-5 h-5" />
				Del på WhatsApp
			</a>
			<div class="text-center md:text-left">
				<p class="text-xs text-gray-500 uppercase font-bold tracking-wider mb-1">Hvordan det fungerer</p>
				<p class="text-sm text-gray-400">Oppgi din vervede venns WhatsApp i kassen.</p>
			</div>
		</div>
	</div>
</section>
