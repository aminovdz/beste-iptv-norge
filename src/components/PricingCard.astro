---
import { Check, Zap, Star, ShieldCheck } from 'lucide-astro';

interface Props {
	title: string;
	price: string;
	period: string;
	features: string[];
	highlight?: boolean;
	popular?: boolean;
	isYearly?: boolean;
}

const { title, price, period, features, highlight = false, popular = false, isYearly = false } = Astro.props;
---

<div class={`relative flex flex-col p-8 rounded-3xl transition-all duration-300 hover:scale-[1.02] ${highlight ? 'glass border-primary/50 bg-primary/5' : 'glass'}`}>
	{popular && (
		<span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-widest shadow-xl">
			Mest Populær
		</span>
	)}

	<div class="mb-8">
		<h3 class="text-xl font-bold mb-2">{title}</h3>
		<div class="flex items-baseline gap-1">
			<span class="text-5xl font-extrabold tracking-tight">{price}</span>
			<span class="text-gray-400 font-medium">/ {period}</span>
		</div>
	</div>

	{isYearly && (
		<div class="mb-6 p-3 rounded-xl border border-primary/30 bg-primary/10 animate-pulse-gentle flex items-center gap-3">
			<div class="p-2 bg-primary rounded-lg">
				<Star class="w-4 h-4 text-white fill-white" />
			</div>
			<div>
				<p class="text-xs font-bold text-white uppercase tracking-tighter leading-none">Inkluderer</p>
				<p class="text-[10px] text-primary-light font-medium leading-none mt-1">Gratis Premium Spiller</p>
			</div>
		</div>
	)}

	<ul class="space-y-4 mb-8 flex-1">
		{features.map((feature) => (
			<li class="flex items-start gap-3 text-sm text-gray-300">
				<Check class="w-5 h-5 text-primary shrink-0" />
				{feature}
			</li>
		))}
	</ul>

	<div class="space-y-4">
		<a 
			href={`https://wa.me/18036582620?text=Jeg%20ønsker%20å%20bestille%20${title}%20abonnement`} 
			target="_blank" 
			rel="noopener noreferrer" 
			class={`w-full py-4 rounded-2xl font-bold transition-all text-center block ${highlight ? 'bg-primary hover:bg-red-700 text-white shadow-xl shadow-primary/20' : 'bg-white/10 hover:bg-white/20 text-white'}`}
		>
			Kjøp Nå
		</a>
		
		<div class="flex items-center justify-center gap-2 text-[10px] text-gray-500 uppercase font-bold tracking-widest">
			<ShieldCheck class="w-3 h-3 text-green-500" />
			30-dagers garanti
		</div>
	</div>
</div>
