---
import { MessageCircle, Mail, MapPin } from 'lucide-astro';
---

<section id="section-contact-omega" class="py-24 bg-black/30">
	<div class="max-container">
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
			<div>
				<h2 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight">Kontakt oss</h2>
				<p class="text-gray-400 mb-12 text-lg">Vi er her for å hjelpe deg. Ta kontakt via WhatsApp eller e-post hvis du har spørsmål om våre tjenester eller installasjon.</p>

				<div class="space-y-8">
					<div class="flex items-center gap-6">
						<div class="w-14 h-14 bg-[#25D366]/10 rounded-2xl flex items-center justify-center">
							<MessageCircle class="w-7 h-7 text-[#25D366]" />
						</div>
						<div>
							<p class="text-sm text-gray-500 uppercase font-bold tracking-widest">WhatsApp</p>
							<a href="https://wa.me/18036582620" class="text-xl font-bold hover:text-[#25D366] transition-colors">+1 803 658 2620</a>
						</div>
					</div>

					<div class="flex items-center gap-6">
						<div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center">
							<Mail class="w-7 h-7 text-primary" />
						</div>
						<div>
							<p class="text-sm text-gray-500 uppercase font-bold tracking-widest">E-post</p>
							<a href="mailto:contact@iptv-norge.net" class="text-xl font-bold hover:text-primary transition-colors">contact@iptv-norge.net</a>
						</div>
					</div>

					<div class="flex items-center gap-6">
						<div class="w-14 h-14 bg-secondary/10 rounded-2xl flex items-center justify-center">
							<MapPin class="w-7 h-7 text-secondary" />
						</div>
						<div>
							<p class="text-sm text-gray-500 uppercase font-bold tracking-widest">Tilgjengelighet</p>
							<p class="text-xl font-bold">24/7 Kundestøtte</p>
						</div>
					</div>
				</div>
			</div>

			<div class="glass p-8 md:p-12 rounded-3xl">
				<form class="space-y-6">
					<div>
						<label for="name" class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">Navn</label>
						<input type="text" id="name" name="name" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 text-white focus:outline-hidden focus:border-primary transition-colors" placeholder="Ditt navn" required>
					</div>
					<div>
						<label for="email" class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">E-post</label>
						<input type="email" id="email" name="email" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 text-white focus:outline-hidden focus:border-primary transition-colors" placeholder="din@epost.no" required>
					</div>
					<div>
						<label for="message" class="block text-sm font-bold text-gray-400 uppercase tracking-widest mb-2">Melding</label>
						<textarea id="message" name="message" rows="4" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-4 text-white focus:outline-hidden focus:border-primary transition-colors" placeholder="Hvordan kan vi hjelpe deg?" required></textarea>
					</div>
					<button type="submit" class="btn-primary w-full py-5 text-xl">Send Melding</button>
					<p class="text-center text-xs text-gray-500 mt-4">Ved å sende inn dette skjemaet godtar du våre vilkår.</p>
				</form>
			</div>
		</div>
	</div>
</section>
