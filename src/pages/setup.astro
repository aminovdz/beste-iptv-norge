---
import Layout from '../layouts/Layout.astro';
import { Tv, Smartphone, Monitor, Smartphone as Apple, Laptop, Info, MessageCircle, CheckCircle2, ChevronRight, HelpCircle, ShieldCheck, Zap } from 'lucide-astro';

const title = "Installasjonsguide | Slik setter du opp IPTV Norge";
const description = "Se vår komplette guide for hvordan du installerer Best IPTV Norge på din Smart TV, Firestick eller mobil. Enkelt oppsett av IPTV Norge på 15 minutter.";

const devices = [
	{ id: 'smart-tv', name: 'Smart TV', icon: Tv, description: 'Samsung, LG, Sony.' },
	{ id: 'firestick', name: 'Firestick', icon: Monitor, description: 'Amazon Fire TV Stick.' },
	{ id: 'android', name: 'Android', icon: Smartphone, description: 'Box, Mobil, Nettbrett.' },
	{ id: 'apple', name: 'Apple', icon: Apple, description: 'Apple TV, iPhone, iPad.' },
	{ id: 'windows', name: 'Windows/PC', icon: Laptop, description: 'PC og Laptop.' }
];
---

<Layout title={title} description={description}>
	<div class="pt-32 pb-24 max-container">
		<!-- Hero Section -->
		<div class="flex flex-col lg:flex-row items-center gap-16 mb-24">
			<div class="flex-1 text-center lg:text-left">
				<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border-white/10 mb-8">
					<Zap class="w-4 h-4 text-primary" />
					<span class="text-xs font-bold uppercase tracking-widest text-gray-300">Aktivering på 15 minutter</span>
				</div>
				<h1 class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-tight">Slik kommer du<br />i gang</h1>
				<p class="text-xl text-gray-400 max-w-2xl mx-auto lg:mx-0 leading-relaxed mb-10">
					Vår tjeneste er designet for å være enkel å bruke. Følg vår guide for din enhet og start strømmingen i dag.
				</p>
				<div class="flex flex-wrap justify-center lg:justify-start gap-4">
					<a href="#guide-selector" class="btn-primary inline-flex items-center gap-2">
						Velg din enhet
						<ChevronRight class="w-5 h-5" />
					</a>
					<a href="https://wa.me/18036582620" class="glass px-8 py-4 rounded-full font-bold hover:bg-white/5 transition-all flex items-center gap-2">
						Trenger du hjelp?
					</a>
				</div>
			</div>
			<div class="flex-1 relative">
				<div class="rounded-3xl overflow-hidden shadow-2xl border border-white/10 glass p-2">
					<img 
						src="/images/setup-guide.webp" 
						alt="IPTV Installasjon Guide" 
						class="rounded-2xl w-full h-auto object-cover"
						width="600"
						height="400"
					/>
				</div>
				<div class="absolute -inset-4 bg-primary/20 blur-3xl rounded-full -z-10"></div>
			</div>
		</div>

		<!-- Process Section -->
		<section class="py-24 border-y border-glass-border mb-24">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
				{[
					{ title: "Last ned app", desc: "Vi sender deg navnet på den beste appen for din enhet." },
					{ title: "Send Device ID", desc: "Gi oss din unike kode slik at vi kan koble til din konto." },
					{ title: "Begynn å se", desc: "Start appen på nytt og nyt alle dine favorittkanaler." }
				].map((step, i) => (
					<div class="text-center">
						<div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-primary/20">
							<span class="text-2xl font-black text-primary">{i + 1}</span>
						</div>
						<h3 class="text-xl font-bold mb-2">{step.title}</h3>
						<p class="text-gray-400 text-sm">{step.desc}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Device Selector -->
		<div id="guide-selector" class="scroll-mt-32 mb-16">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-5xl font-black mb-4">Velg din enhet</h2>
				<p class="text-gray-400">Klikk på enheten du vil sette opp.</p>
			</div>
			
			<div class="glass p-2 rounded-[32px] flex flex-wrap justify-center mb-12 gap-2 border border-white/5">
				{devices.map((device) => (
					<button 
						data-device={device.id}
						class="device-tab flex flex-col items-center gap-2 px-8 py-6 rounded-2xl font-bold transition-all hover:bg-white/5 min-w-[140px]"
					>
						<device.icon class="w-8 h-8 mb-2" />
						<span class="text-sm">{device.name}</span>
					</button>
				))}
			</div>

			<div id="device-content" class="min-h-[500px]">
				<div id="default-content" class="text-center py-32 bg-white/2 rounded-[40px] border border-dashed border-white/10">
					<Info class="w-16 h-16 text-primary/30 mx-auto mb-6" />
					<h3 class="text-2xl font-bold text-gray-500 italic">Velg en enhet ovenfor for å se instruksjonene</h3>
				</div>
			</div>
		</div>

		<!-- Templates -->
		<template id="template-smart-tv">
			<div class="animate-fade-up glass p-10 md:p-16 rounded-[48px] border border-white/10 relative overflow-hidden">
				<div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-3xl -z-10"></div>
				<h2 class="text-3xl md:text-4xl font-black mb-8 flex items-center gap-4">
					<Tv class="text-primary w-10 h-10" />
					Oppsett på Smart TV
				</h2>
				<div class="space-y-8">
					<div class="flex gap-6">
						<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-black shrink-0">1</div>
						<p class="text-lg text-gray-300">Åpne App Store på din Samsung eller LG TV og søk etter <strong>IBO Player</strong> eller <strong>IPTV Smarters</strong>.</p>
					</div>
					<div class="flex gap-6">
						<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-black shrink-0">2</div>
						<p class="text-lg text-gray-300">Installer og åpne appen. Du vil se en <strong>MAC-adresse</strong> og en <strong>Device Key</strong> på skjermen.</p>
					</div>
					<div class="flex gap-6">
						<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-black shrink-0">3</div>
						<p class="text-lg text-gray-300">Ta et bilde av koden og send den til oss på WhatsApp. Vi aktiverer din spilleliste umiddelbart.</p>
					</div>
				</div>
			</div>
		</template>

		<template id="template-firestick">
			<div class="animate-fade-up glass p-10 md:p-16 rounded-[48px] border border-white/10 relative overflow-hidden">
				<h2 class="text-3xl md:text-4xl font-black mb-8 flex items-center gap-4">
					<Monitor class="text-primary w-10 h-10" />
					Oppsett på Firestick
				</h2>
				<div class="space-y-8">
					<div class="flex gap-6">
						<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-black shrink-0">1</div>
						<p class="text-lg text-gray-300">Gå til <strong>Innstillinger</strong> > <strong>Min Fire TV</strong> > <strong>Utvikleralternativer</strong> og tillat apper fra ukjente kilder.</p>
					</div>
					<div class="flex gap-6">
						<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-black shrink-0">2</div>
						<p class="text-lg text-gray-300">Installer <strong>Downloader</strong>-appen og bruk koden vi sender deg for å laste ned vår premium-app.</p>
					</div>
					<div class="flex gap-6">
						<div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-black shrink-0">3</div>
						<p class="text-lg text-gray-300">Logg inn med brukernavnet og passordet du mottok ved bestilling.</p>
					</div>
				</div>
			</div>
		</template>

		<!-- Troubleshooting Section -->
		<section class="mt-32">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-black mb-4">Feilsøking for IPTV Norge</h2>
				<p class="text-gray-400">Har du problemer med din Best IPTV Norge tjeneste? Prøv disse raske løsningene.</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{[
					{ q: "Hva gjør jeg hvis kanalen bufres?", a: "Sjekk internetthastigheten din og prøv å starte ruteren på nytt. En kablet tilkobling er alltid best." },
					{ q: "Koden min fungerer ikke lenger", a: "Sjekk at abonnementet ditt ikke har utløpt. Kontakt oss på WhatsApp for fornyelse." },
					{ q: "Jeg ser ikke alle kanalene", a: "Prøv å oppdatere spillelisten i app-innstillingene eller start appen på nytt." },
					{ q: "Kan jeg bruke min egen app?", a: "Ja, vi støtter alle M3U og Xtream Codes kompatible apper." }
				].map((item) => (
					<div class="glass p-8 rounded-3xl border border-white/5">
						<h4 class="text-white font-bold mb-3 flex items-center gap-2">
							<HelpCircle class="w-5 h-5 text-primary" />
							{item.q}
						</h4>
						<p class="text-gray-400 text-sm leading-relaxed">{item.a}</p>
					</div>
				))}
			</div>
		</section>

		<div class="mt-32 glass p-10 md:p-20 rounded-[60px] text-center border border-primary/20 bg-primary/5">
			<h3 class="text-3xl md:text-5xl font-black mb-6 italic">Får du det ikke til?</h3>
			<p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">Vår kundestøtte kan fjernstyre oppsettet for deg hvis du trenger ekstra hjelp. Vi er her for å sikre at du får TV-en din opp og gå.</p>
			<a href="https://wa.me/18036582620" class="btn-primary flex items-center justify-center gap-3 w-fit mx-auto px-10 py-5">
				<MessageCircle class="w-7 h-7" />
				Få hjelp på WhatsApp
			</a>
		</div>
	</div>
</Layout>

<script>
	const tabs = document.querySelectorAll('.device-tab');
	const content = document.getElementById('device-content');

	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			tabs.forEach(t => t.classList.remove('bg-primary', 'text-white', 'scale-105', 'shadow-xl'));
			tab.classList.add('bg-primary', 'text-white', 'scale-105', 'shadow-xl');

			const deviceId = tab.getAttribute('data-device');
			const template = document.getElementById(`template-${deviceId}`);
			
			if (content && template) {
				content.innerHTML = '';
				content.appendChild((template as HTMLTemplateElement).content.cloneNode(true));
			} else if (content) {
				content.innerHTML = `
					<div class="animate-fade-up glass p-10 md:p-16 rounded-[48px] border border-white/10 text-center py-32">
						<h3 class="text-3xl font-black mb-6">Instruksjoner for ${deviceId}</h3>
						<p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">Vi har detaljerte guider for denne enheten klare på WhatsApp. Kontakt oss for øyeblikkelig hjelp.</p>
						<a href="https://wa.me/18036582620" class="btn-primary inline-flex items-center gap-3">
							<MessageCircle class="w-6 h-6" />
							Få guiden nå
						</a>
					</div>
				`;
			}
		});
	});
</script>
