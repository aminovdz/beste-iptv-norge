---
import Layout from '../layouts/Layout.astro';
import LiveScores from '../components/LiveScores.astro';

const title = "Live Sport Resultater & Kampoppsett | IPTV Norge";
const description = "Følg live sport resultater, kampoppsett og resultater i sanntid. Ikke gå glipp av et øyeblikk med action med IPTV Norges premium sportskanaler.";
---

<Layout title={title} description={description} lang="no">
	<!-- Hero Section -->
	<section class="relative pt-32 pb-16 overflow-hidden border-b border-white/5">
		<div class="absolute inset-0 z-0 bg-primary/5">
			<div class="absolute inset-0 bg-gradient-to-b from-bg-dark/80 via-bg-dark/90 to-bg-dark"></div>
		</div>

		<div class="max-container relative z-10 text-center max-w-3xl">
			<h1 class="text-4xl md:text-6xl font-black mb-6 tracking-tighter">
				Live <span class="text-gradient">Kamp Senter</span>
			</h1>
			<p class="text-xl text-gray-400">
				Hold deg oppdatert med live resultater fra de beste ligaene rundt om i verden. Se alle disse kampene live og i 4K med et IPTV Norge-abonnement.
			</p>
		</div>
	</section>

	<LiveScores />

    <!-- Promotional Banner -->
    <section class="py-12 bg-white/2">
        <div class="max-container max-w-4xl text-center">
            <div class="glass p-12 rounded-3xl border border-primary/20 bg-primary/5">
                <h3 class="text-3xl font-black mb-4">Vil du se disse kampene live?</h3>
                <p class="text-gray-300 text-lg mb-8">Få tilgang til hver eneste sportskanal globalt i ekte 4K uten buffering.</p>
                <a href="/#section-pricing" class="btn-primary inline-flex px-8 py-4 text-lg font-bold">
                    Se Premium Planer
                </a>
            </div>
        </div>
    </section>
</Layout>
