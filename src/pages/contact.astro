---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { MessageCircle, Mail, MapPin, Clock } from 'lucide-astro';

const title = "Kontakt Oss | IPTV Norge Kundestøtte";
const description = "Trenger du hjelp med din IPTV-tjeneste? Kontakt oss via WhatsApp eller e-post for rask og effektiv kundestøtte 24/7.";
---

<Layout title={title} description={description}>
	<div class="pt-32 pb-24 max-container">
		<div class="text-center mb-16">
			<h1 class="text-4xl md:text-6xl font-black mb-6 tracking-tighter">Kontakt Oss</h1>
			<p class="text-gray-400 max-w-2xl mx-auto">Vårt team er her for å hjelpe deg med alt fra tekniske spørsmål til nye bestillinger.</p>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-20">
			<div class="glass p-8 rounded-3xl text-center flex flex-col items-center">
				<div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mb-6">
					<MessageCircle class="w-8 h-8 text-primary" />
				</div>
				<h3 class="text-xl font-bold mb-2">WhatsApp</h3>
				<p class="text-gray-400 text-sm mb-6">Raskest respons for teknisk hjelp.</p>
				<a href="https://wa.me/18036582620" class="text-primary font-bold hover:underline">+1 (803) 658-2620</a>
			</div>

			<div class="glass p-8 rounded-3xl text-center flex flex-col items-center">
				<div class="w-16 h-16 bg-secondary/20 rounded-full flex items-center justify-center mb-6">
					<Mail class="w-8 h-8 text-secondary" />
				</div>
				<h3 class="text-xl font-bold mb-2">E-post</h3>
				<p class="text-gray-400 text-sm mb-6">For generelle henvendelser.</p>
				<a href="mailto:contact@iptv-norge.net" class="text-secondary font-bold hover:underline">contact@iptv-norge.net</a>
			</div>

			<div class="glass p-8 rounded-3xl text-center flex flex-col items-center">
				<div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center mb-6">
					<Clock class="w-8 h-8 text-gray-400" />
				</div>
				<h3 class="text-xl font-bold mb-2">Åpningstider</h3>
				<p class="text-gray-400 text-sm mb-2">Kundestøtte: 24/7</p>
				<p class="text-gray-400 text-sm">Salg: 08:00 - 22:00</p>
			</div>
		</div>

		<ContactForm />

		<div class="mt-20 flex flex-col items-center text-center">
			<div class="flex items-center gap-2 text-gray-500 mb-4">
				<MapPin class="w-4 h-4" />
				<span>Karl Johans gate 22, 0159 Oslo, Norge</span>
			</div>
			<p class="text-xs text-gray-600 max-w-md italic">Merk: Vi har ikke et fysisk utsalgssted for kunder. All støtte og aktivering skjer digitalt via våre nettplattformer.</p>
		</div>
	</div>
</Layout>
